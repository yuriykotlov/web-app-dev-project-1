<div id="add-meal">
    <form class="ui stacked segment form" action="/course/{{id}}/addmeal" method="POST">
        <div class="two fields">
            <div class="field">
                <label>Name</label>
                <input type="text" name="name" autofocus required title="Enter a name for this meal">
            </div>
            <div class="field">
                <label>Description</label>
                <input type="text" name="description" required title="Enter a description for this meal">
            </div>
            <div class="field">
                <label>Price €</label>
                <input type="text" name="price" required title="Enter a price in Euros">
            </div>
            <div class="field">
                <label>Rating ⭐</label>
                <input type="number" name="rating" required>
            </div>
        </div>
        <button class="ui blue submit button">Add Meal</button>
    </form>
</div>