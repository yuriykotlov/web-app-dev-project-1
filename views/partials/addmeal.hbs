<div id="add-meal">
    <h2><i>Add a Meal</i></h2>
    <form class="ui stacked segment form" action="/course/{{thisCourse.id}}/addmeal" method="POST">
        <div class="two fields">
            <div class="field">
                <label>Name</label>
                <input type="text" name="name" autofocus required title="Enter a name for this meal">
            </div>
            <div class="field">
                <label>Description</label>
                <input type="text" name="description" required title="Enter a description for this meal">
            </div>
            <div class="field">
                <label>Price €</label>
                <input type="number" step="0.01" min="0" max="999.99" name="price" required title="Enter a price in Euros">
            </div>
            <div class="field">
                <label>Rating ⭐</label>
                <input type="number" step="0.25" min="0" max="5" name="rating" required>
            </div>
        </div>
        <button class="ui blue submit button">Add Meal</button>
    </form>
</div>