<div class="menu-course-container ui card">
    <div class="image">
        <img src="{{picture.url}}">
    </div>
    <div class="content">
        <h2><i>{{uppercase name}}</i></h2>
        
        {{#if meals}}
            <p>Number of meals: {{meals.length}}</p>
        {{else}}
            <p>No meals in this course yet!</p>
        {{/if}}

        <a href="/course/{{id}}"><i class="icon hamburger"></i>See meals</a>

        <div class="course-controls">
            <a href="/menu/deletecourse/{{id}}" title="Delete Course">
                <i class="ui white trash icon"></i>
            </a>
        </div>
    </div>
</div>