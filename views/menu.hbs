{{> header id="menu"}}

<head>
    <link rel="stylesheet" href="/css/menu.css">
</head>

<section class="ui center aligned middle aligned segment">
  
  <h1>Our Menu</h1>
  {{#each course}}
    <div class="menu-items-container ui center aligned segment">
      <h2>{{name}}</h2>
      {{#if meals}}
        <p>Number of meals: {{meals.length}}</p>
        <a href="/course/{{id}}"><i class="icon hamburger"></i> See meals</a>
      {{/if}}
    </div>
  {{/each}}
</section>